{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Context Bridge",
  "uid": "context-bridge",
  "tags": ["context-bridge"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Writes / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(cb_memory_writes_total[5m]))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Queries / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(cb_queries_total[5m]))" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dedup ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(cb_chunks_deduped_total[5m])) / clamp_min(sum(rate(cb_chunks_deduped_total[5m])) + sum(rate(cb_chunks_stored_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg tokens / query",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(cb_query_tokens_used_sum[5m])) / clamp_min(sum(rate(cb_query_tokens_used_count[5m])), 1)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tokens used per query (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(cb_query_tokens_used_bucket[5m])) by (le))"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(cb_query_tokens_used_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(cb_request_latency_seconds_bucket[5m])) by (le))"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(cb_request_latency_seconds_bucket[5m])) by (le))"
        },
        {
          "refId": "C",
          "legendFormat": "p99",
          "expr": "histogram_quantile(0.99, sum(rate(cb_request_latency_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Write outcomes / sec (stored vs deduped)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "refId": "A", "legendFormat": "stored", "expr": "sum(rate(cb_chunks_stored_total[5m]))" },
        { "refId": "B", "legendFormat": "deduped", "expr": "sum(rate(cb_chunks_deduped_total[5m]))" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Chunks returned per query (avg)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(cb_query_chunks_returned_sum[5m])) / clamp_min(sum(rate(cb_query_chunks_returned_count[5m])), 1)"
        }
      ]
    }
  ]
}
